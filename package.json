{
  "name": "@ghostbroker/agent-client",
  "version": "0.2.0",
  "description": "Official TypeScript SDK for autonomous trading agents on the GhostBroker dark pool. Authenticate with a persistent API key, admit your agent, submit encrypted intents, listen for settlement.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zaikaman/ghostbroker-agent.git"
  },
  "homepage": "https://github.com/zaikaman/ghostbroker-agent#readme",
  "bugs": {
    "url": "https://github.com/zaikaman/ghostbroker-agent/issues",
    "email": "security@ghostbroker.io"
  },
  "keywords": [
    "ghostbroker",
    "dark-pool",
    "trading",
    "agent",
    "autonomous-agent",
    "ai-agent",
    "tee",
    "terminal3",
    "blockchain",
    "ethereum",
    "sdk",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings=0"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.0.0",
    "@terminal3/t3n-sdk": "^3.5.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
